# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medfield
DB_USER=medfield_user
DB_PASSWORD=medfield_password
DB_POOL_MIN=5
DB_POOL_MAX=50

# Authentication
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Redis (required for horizontal scaling)
REDIS_URL=redis://localhost:6379

# Auto-Scaling Configuration
SCALING_MODE=auto
SCALING_MAX_WORKERS=4
SCALING_VERTICAL_CPU_WARM=60
SCALING_VERTICAL_CPU_HOT=75
SCALING_VERTICAL_CPU_CRITICAL=85
SCALING_HORIZONTAL_CPU_TRIGGER=90
SCALING_HORIZONTAL_MEMORY_TRIGGER=90
SCALING_HORIZONTAL_LATENCY_TRIGGER=5000
SCALING_HORIZONTAL_ERROR_RATE_TRIGGER=10
SCALING_COOLDOWN_MINUTES=10
SCALING_METRICS_INTERVAL=10000
SCALING_EVALUATION_INTERVAL=30000

# External Services
DHIS2_URL=https://dhis2.example.org
DHIS2_USER=admin
DHIS2_PASSWORD=district
SMS_GATEWAY_API_KEY=your_sms_api_key
SMS_GATEWAY_SENDER=MedField

# Logging
LOG_LEVEL=info
