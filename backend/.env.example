# MedField CHW Platform - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================
# REQUIRED - Server will not start without these
# =============================================

# Server Configuration
PORT=3007
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5434
DB_NAME=medfield
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT Secrets - CRITICAL: Generate strong random strings in production!
# Use: openssl rand -base64 32 (Linux/Mac) or use an online generator
JWT_SECRET=your_jwt_secret_min_32_chars_generate_new
REFRESH_TOKEN_SECRET=your_refresh_secret_min_32_chars_generate_new

# =============================================
# OPTIONAL - Defaults provided if not set
# =============================================

# Client URL for CORS
CLIENT_URL=http://localhost:3000

# Redis Configuration (for production scaling)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# API Documentation
SWAGGER_URL=/api-docs

# JWT Expiration (default: 15 minutes)
JWT_EXPIRES_IN=15m

# Logging
LOG_LEVEL=info

# =============================================
# TEST ACCOUNTS (change in production!)
# =============================================
# Admin: admin / admin123
# Supervisor: supervisor / supervisor123
# CHW: chw001 / password123
#
# WARNING: Change all default passwords before production deployment!