# MedField Dashboard Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_API_URL=http://localhost:3005/api

# App Configuration
VITE_APP_NAME=MedField Dashboard
VITE_APP_VERSION=2.0.0

# Example values for different environments:

# Development (local machine)
# VITE_API_URL=http://localhost:3005/api

# Staging
# VITE_API_URL=https://staging-api.medfield.org/api

# Production
# VITE_API_URL=https://api.medfield.org/api
