# MedField Mobile App Environment Configuration
# Copy this file to .env and fill in your actual values

# API Configuration
EXPO_PUBLIC_API_URL=http://your-api-server:3007/api
EXPO_PUBLIC_API_TIMEOUT=30000

# App Configuration
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_ENABLE_LOGGING=true
EXPO_PUBLIC_SYNC_INTERVAL=300000

# Example values for different environments:

# Development (local machine)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3007/api

# Staging
# EXPO_PUBLIC_API_URL=https://staging-api.medfield.org/api

# Production
# EXPO_PUBLIC_API_URL=https://api.medfield.org/api
